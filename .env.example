GEMINI_API_KEY=coloque_sua_chave_gemini_aqui

# Google Calendar
# Use "primary", o ID do calendario ou o nome visivel, como 1ads.
GOOGLE_CALENDAR_ID=1ads
# Caminho local para o token gerado por scripts/auth_google.py.
GOOGLE_TOKEN_FILE=token.json

# Email SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=seu_email@gmail.com
SMTP_PASSWORD=sua_senha_de_app
EMAIL_FROM=seu_email@gmail.com
EMAIL_TO=seu_email@gmail.com

# Configuracao do agente
TIMEZONE=America/Sao_Paulo
DAILY_LOOKAHEAD_DAYS=31
GEMINI_MODEL=gemini-2.5-flash
